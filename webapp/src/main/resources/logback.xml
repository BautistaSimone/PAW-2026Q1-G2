<configuration debug="true">
    <appender name="errors" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/errors.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/paw-2026a-02.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>5</maxHistory> <!-- Last 5 days get stored -->
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="general" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/general.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/paw-2026a-02.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>5</maxHistory> <!-- Last 5 days get stored -->
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>
    
    <root level="WARN">
        <appender-ref ref="errors" />
    </root>

    <logger name="ar.edu.itba.paw" level="INFO"> 
        <appender-ref ref="general" /> 
    </logger> 

    <logger name="ar.edu.itba.paw.services" level="DEBUG" additivity="false"> 
        <appender-ref ref="general" /> 
    </logger> 
</configuration>